{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "bedrock: serve - frontend",
            "type": "shell",
            "command": "npm run serve",
            "options": {
                "cwd": "${workspaceFolder}/bedrock/frontend"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true,
                "group": "common"
            },
            "group": "build",
            "problemMatcher": [],
        },
        {
            "label": "bedrock: pull",
            "type": "shell",
            "command": "docker-compose -f docker-compose.yml pull",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true,
                "group": "common"
            },
            "group": "build",
            "problemMatcher": [],
        },
        {
            "label": "bedrock: up",
            "type": "shell",
            "command": "docker-compose -f docker-compose.yml up",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true,
                "group": "common"
            },
            "group": "none",
            "problemMatcher": [],
            "dependsOn": [
                "bedrock: pull"
            ],
            "dependsOrder": "parallel",
        },
        {
            "label": "bedrock: stop",
            "type": "shell",
            "command": "docker-compose -f docker-compose.yml stop",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true,
                "group": "common"
            },
            "group": "none",
            "problemMatcher": [],
        },
    ]
}